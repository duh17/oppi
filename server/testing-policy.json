{
  "version": 2,
  "gates": {
    "pr-fast": [
      "check",
      "test:coverage"
    ],
    "nightly-deep": {
      "server": ["check", "test:coverage", "test:e2e:linux"],
      "apple": [
        "cd clients/apple && bash scripts/check-coverage.sh",
        "cd clients/apple && bash scripts/test-ui.sh --full-suite",
        "cd clients/apple && bash scripts/e2e.sh"
      ]
    },
    "release-preflight": {
      "server": ["check", "test:coverage", "telemetry:review:gate"],
      "apple": ["cd clients/apple && bash scripts/check-coverage.sh"]
    }
  },
  "ci": {
    "note": "GitHub Actions workflows not yet created. Gates run locally.",
    "prCommand": "cd server && npm run test:gate:pr-fast",
    "nightlyNote": "Run server npm scripts + apple scripts separately from repo root."
  },
  "docs": {
    "canonical": "docs/testing/README.md"
  }
}
