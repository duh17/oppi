{
  "version": 2,
  "gates": {
    "pr-fast": [
      "check",
      "test:coverage"
    ],
    "nightly-deep": [
      "check",
      "test:coverage",
      "test:ios:coverage",
      "test:ios:ui:full",
      "test:e2e:linux",
      "test:ios:e2e"
    ],
    "release-preflight": [
      "check",
      "test:coverage",
      "test:ios:coverage",
      "telemetry:review:gate"
    ]
  },
  "ci": {
    "note": "GitHub Actions workflows not yet created. Gates run locally via npm scripts.",
    "prCommand": "cd server && npm run test:gate:pr-fast",
    "nightlyCommand": "cd server && npm run test:gate:nightly-deep"
  },
  "docs": {
    "canonical": "docs/testing/README.md"
  }
}
