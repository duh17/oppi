      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisLabel": "%",
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 20,
            "pointSize": 3,
            "showPoints": "auto",
            "spanNulls": false
          },
          "unit": "percent",
          "min": 0
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "cpu_user"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "User"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "cpu_system"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "System"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "cpu_total"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Total"
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "rawQueryText": "SELECT ts_ms / 1000 AS time, cpu_user, cpu_system, cpu_total FROM server_metric_samples WHERE ts_ms >= ${__from} AND ts_ms <= ${__to} ORDER BY ts_ms",
